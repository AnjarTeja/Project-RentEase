<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:id="@+id/register_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="40dp">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/register_back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/white" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/register_logo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:contentDescription="@string/app_logo"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_aplikasi" />

        <!-- Title -->
        <TextView
            android:id="@+id/register_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="Buat Akun"
            android:textColor="@color/text_dark"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/register_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:text="Daftarkan akun baru untuk mulai menyewa"
            android:textColor="@color/text_light"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp" />

        <!-- Name Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Nama Lengkap"
            android:textColor="@color/text_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/name_input"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/edit_text_background"
            android:hint="Masukkan nama lengkap"
            android:inputType="textPersonName"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp" />

        <!-- Email Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Email"
            android:textColor="@color/text_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/register_email_input"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/edit_text_background"
            android:hint="Masukkan email"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp" />

        <!-- Phone Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Nomor Telepon"
            android:textColor="@color/text_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/phone_input"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/edit_text_background"
            android:hint="Contoh: 081234567890"
            android:inputType="phone"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp" />

        <!-- Password Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Kata Sandi"
            android:textColor="@color/text_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Password Input with Toggle -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/edit_text_background">

            <EditText
                android:id="@+id/register_password_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Minimal 6 karakter"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:paddingEnd="48dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/register_toggle_password"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="Toggle password"
                android:scaleType="centerInside"
                android:src="@drawable/ic_password_show" />

        </FrameLayout>

        <!-- Confirm Password Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Konfirmasi Kata Sandi"
            android:textColor="@color/text_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Confirm Password Input with Toggle -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="28dp"
            android:background="@drawable/edit_text_background">

            <EditText
                android:id="@+id/confirm_password_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Konfirmasi kata sandi"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:paddingEnd="48dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/confirm_toggle_password"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="Toggle password"
                android:scaleType="centerInside"
                android:src="@drawable/ic_password_show" />

        </FrameLayout>

        <!-- Register Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/register_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="20dp"
            android:text="Daftar"
            android:textColor="@color/tech_dark_bg"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary_color"
            app:cornerRadius="12dp" />

        <!-- Login Link -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sudah punya akun? "
                android:textColor="@color/text_light"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/login_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ripple_text_effect"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                android:text="Masuk"
                android:textColor="@color/primary_color"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
