<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_user_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard_gradient"
    android:orientation="vertical">

    <!-- ============================================ -->
    <!-- FIXED HEADER SECTION (PINS TO THE TOP)       -->
    <!-- ============================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_user"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        android:elevation="6dp">

        <!-- Top Bar Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Brand Logo -->
            <ImageView
                android:layout_width="160dp"
                android:layout_height="55dp"
                android:src="@drawable/logo_dalamapk"
                android:scaleType="fitStart"
                android:contentDescription="RentEase Logo" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <!-- Profile Avatar Wrapper -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_profile"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="22dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#2A2A35">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Placeholder -->
                    <ImageView
                        android:id="@+id/iv_topbar_avatar_placeholder"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        app:tint="@color/white"
                        android:contentDescription="Profile Placeholder" />

                    <!-- Actual Avatar -->
                    <ImageView
                        android:id="@+id/iv_topbar_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="User Avatar" />

                </FrameLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Welcome Text Banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selamat Datang,"
                android:textColor="#A0AEC0"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/user_name_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Nama Pengguna"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Quick Stats Glass Cards Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Active Stat Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_stat_card_user"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/stat_active_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/success_color"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="Disewa"
                    android:textColor="#A0AEC0"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Pending Stat Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:background="@drawable/bg_stat_card_user"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/stat_pending_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/warning_color"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="Menunggu"
                    android:textColor="#A0AEC0"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Completed Stat Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_stat_card_user"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/stat_completed_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/primary_color"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="Selesai"
                    android:textColor="#A0AEC0"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ============================================ -->
    <!-- SCROLLABLE BODY AREA (VERTICAL SCROLL)       -->
    <!-- ============================================ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ============================================ -->
            <!-- DYNAMIC HORIZONTAL MENU SCROLL VIEW          -->
            <!-- ============================================ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="10dp"
                    android:text="Layanan RentEase"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Horizontal Scroll for Menu Items -->
                <HorizontalScrollView
                    android:id="@+id/menu_scroll_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:overScrollMode="never">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp"
                        android:paddingBottom="8dp">

                        <!-- Item 1: Sewa Barang -->
                        <LinearLayout
                            android:id="@+id/menu_browse"
                            android:layout_width="110dp"
                            android:layout_height="115dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_card_dark"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="14dp">

                            <View
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_green" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="-30dp"
                                android:src="@drawable/ic_rent"
                                app:tint="@color/white"
                                android:contentDescription="Sewa Icon" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:gravity="center"
                                android:text="Sewa Barang"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                        <!-- Item 2: Upload Barang -->
                        <LinearLayout
                            android:id="@+id/menu_add_item"
                            android:layout_width="110dp"
                            android:layout_height="115dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_card_dark"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="14dp">

                            <View
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_cyan" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="-30dp"
                                android:src="@drawable/ic_add_item"
                                app:tint="@color/white"
                                android:contentDescription="Upload Icon" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:gravity="center"
                                android:text="Upload Barang"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                        <!-- Item 3: Transaksi Saya -->
                        <LinearLayout
                            android:id="@+id/menu_my_transactions"
                            android:layout_width="110dp"
                            android:layout_height="115dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_card_dark"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="14dp">

                            <View
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_orange" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="-30dp"
                                android:src="@drawable/ic_transaction"
                                app:tint="@color/white"
                                android:contentDescription="Transaksi Icon" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:gravity="center"
                                android:text="Transaksi Saya"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                        <!-- Item 4: Barang Saya -->
                        <LinearLayout
                            android:id="@+id/menu_my_items"
                            android:layout_width="110dp"
                            android:layout_height="115dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_card_dark"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="14dp">

                            <View
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_purple" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="-30dp"
                                android:src="@drawable/ic_my_items"
                                app:tint="@color/white"
                                android:contentDescription="Barang Saya Icon" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:gravity="center"
                                android:text="Barang Saya"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                        <!-- Item 5: Permintaan Sewa (Incoming Rentals for Owner) -->
                        <LinearLayout
                            android:id="@+id/menu_incoming_rentals"
                            android:layout_width="110dp"
                            android:layout_height="115dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_card_dark"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="14dp">

                            <View
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_cyan" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="-30dp"
                                android:src="@drawable/ic_transaction"
                                app:tint="@color/white"
                                android:contentDescription="Permintaan Sewa Icon" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:gravity="center"
                                android:text="Permintaan Sewa"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                        <!-- Item 6: Riwayat Sewa -->
                        <LinearLayout
                            android:id="@+id/menu_history"
                            android:layout_width="110dp"
                            android:layout_height="115dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_card_dark"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="14dp">

                            <View
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_menu_icon_circle" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="-30dp"
                                android:src="@drawable/ic_history"
                                app:tint="@color/white"
                                android:contentDescription="Riwayat Icon" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:gravity="center"
                                android:text="Riwayat Sewa"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                        <!-- Item 6: Bantuan -->
                        <LinearLayout
                            android:id="@+id/menu_help"
                            android:layout_width="110dp"
                            android:layout_height="115dp"
                            android:background="@drawable/bg_card_dark"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="14dp">

                            <View
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_menu_icon_circle" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="-30dp"
                                android:src="@drawable/ic_help"
                                app:tint="@color/white"
                                android:contentDescription="Bantuan Icon" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:gravity="center"
                                android:text="Bantuan"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </LinearLayout>

                </HorizontalScrollView>

            </LinearLayout>

            <!-- ============================================ -->
            <!-- MARKETPLACE PRODUCTS LIST / RECYCLER VIEW   -->
            <!-- ============================================ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="24dp">

                <!-- Title and Count -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Barang Rekomendasi"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_item_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 barang"
                        android:textColor="#A0AEC0"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Loading State -->
                <ProgressBar
                    android:id="@+id/progress_items"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:layout_marginVertical="24dp"
                    android:indeterminateTint="@color/primary_color"
                    android:visibility="gone" />

                <!-- Empty State -->
                <LinearLayout
                    android:id="@+id/empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="32dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_info"
                        app:tint="#A0AEC0"
                        android:contentDescription="Empty State Icon" />

                    <TextView
                        android:id="@+id/tv_empty_message"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Belum ada barang yang disewakan"
                        android:textColor="#A0AEC0"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:scrollbars="none" />

                <!-- Footer brand tagline -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:gravity="center"
                    android:text="RentEase v1.0 — Ambil di tempat dengan jaminan KTP fisik"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
