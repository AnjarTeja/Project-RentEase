<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Beri Rating"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_rating_item_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama Barang"
        android:textColor="@color/text_light"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <!-- Star Rating Row -->
    <LinearLayout
        android:id="@+id/star_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/star_1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="1 star" />

        <ImageView
            android:id="@+id/star_2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="2 stars" />

        <ImageView
            android:id="@+id/star_3"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="3 stars" />

        <ImageView
            android:id="@+id/star_4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="4 stars" />

        <ImageView
            android:id="@+id/star_5"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="5 stars" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_rating_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap bintang untuk memberi rating"
        android:textColor="@color/text_hint"
        android:textSize="13sp"
        android:layout_marginBottom="24dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_rating"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Batal"
            android:textColor="@color/text_light"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit_rating"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/primary_color"
            android:text="Kirim"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
