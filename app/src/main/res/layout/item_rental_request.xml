<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card_dark"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Row 1: Item name + Status Badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_item_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nama Barang"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="Pending"
            android:textColor="@color/warning_color"
            android:textSize="10sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Row 2: Renter name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="User"
            android:src="@drawable/ic_person"
            android:tint="@color/text_light" />

        <TextView
            android:id="@+id/tv_renter_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Penyewa"
            android:textColor="@color/text_light"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Row 3: Duration + Date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="Tanggal"
            android:src="@drawable/ic_calendar"
            android:tint="@color/text_light" />

        <TextView
            android:id="@+id/tv_rental_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="01 Jan 2026 — 3 hari"
            android:textColor="@color/text_light"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Row 4: Action Buttons (only visible for pending) -->
    <LinearLayout
        android:id="@+id/action_buttons_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_approve"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_btn_approve"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="✓ Setujui"
            android:textColor="@color/success_color"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_reject"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_btn_reject"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="✕ Tolak"
            android:textColor="@color/error_color"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
