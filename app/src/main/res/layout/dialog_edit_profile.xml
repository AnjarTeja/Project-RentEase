<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/tech_card_bg"
    app:cardElevation="0dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Edit Profil"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#2A2A35">
                    
                    <ImageView
                        android:id="@+id/iv_edit_placeholder"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        android:tint="@color/text_light" />
                        
                    <ImageView
                        android:id="@+id/iv_edit_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />
                        
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/btn_pick_avatar"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Pilih Foto Baru"
                    android:textColor="@color/primary_color"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground" />
            </LinearLayout>

            <!-- Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Nama Lengkap"
                android:textColor="@color/text_light"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_edit_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_search_bar"
                android:hint="Masukkan nama lengkap"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <!-- Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Nomor Telepon"
                android:textColor="@color/text_light"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_edit_phone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_search_bar"
                android:hint="Misal: 08123456789"
                android:inputType="phone"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <!-- NIK Container -->
            <LinearLayout
                android:id="@+id/container_nik"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="NIK (No. KTP)"
                    android:textColor="@color/text_light"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/et_edit_nik"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_search_bar"
                    android:hint="Misal: 3201234567890001"
                    android:inputType="number"
                    android:maxLength="16"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_hint"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Address Container -->
            <LinearLayout
                android:id="@+id/container_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Alamat Domisili"
                    android:textColor="@color/text_light"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/et_edit_address"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_search_bar"
                    android:gravity="top|start"
                    android:hint="Masukkan alamat tempat tinggal saat ini"
                    android:inputType="textMultiLine"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_hint"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="end"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel_edit"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Batal"
                    android:textColor="@color/text_hint" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_edit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/primary_color"
                    android:text="Simpan"
                    android:textColor="@color/white"
                    app:cornerRadius="8dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.cardview.widget.CardView>
