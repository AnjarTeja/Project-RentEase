<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_petugas_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ============================================ -->
        <!-- HEADER SECTION                               -->
        <!-- ============================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_petugas"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="0dp"
            android:paddingBottom="14dp">

            <!-- Logo -->
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="120dp"
                android:layout_marginBottom="4dp"
                android:adjustViewBounds="true"
                android:contentDescription="RentEase Logo"
                android:scaleType="fitStart"
                android:src="@drawable/logo_dalamapk" />

            <!-- Profile Row: Clickable → Profile Page -->
            <LinearLayout
                android:id="@+id/profile_section_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stat_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">

                <!-- Avatar -->
                <androidx.cardview.widget.CardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#2A2A35">

                    <ImageView
                        android:id="@+id/iv_dashboard_avatar_placeholder"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="Avatar"
                        android:src="@drawable/ic_person" />
                        
                    <ImageView
                        android:id="@+id/iv_dashboard_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                </androidx.cardview.widget.CardView>

                <!-- Name + Role -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/user_name_display_petugas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Petugas"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Staff — Panel Operasional"
                        android:textColor="@color/primary_color"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Chevron -->
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="Profil"
                    android:src="@drawable/ic_chevron_right" />

            </LinearLayout>

            <!-- Stat Summary Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <!-- Pending -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="8dp">

                    <TextView
                        android:id="@+id/stat_pending_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/warning_color"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Pending"
                        android:textColor="@color/text_light"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Disetujui -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="5dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="8dp">

                    <TextView
                        android:id="@+id/stat_approved_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/success_color"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Disetujui"
                        android:textColor="@color/text_light"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Barang -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="8dp">

                    <TextView
                        android:id="@+id/stat_items_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary_color"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Barang"
                        android:textColor="@color/text_light"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- MENU SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Menu Operasional"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">
                
                <LinearLayout
                    android:id="@+id/verify_rental_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_card_dark"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="20dp">
                    <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_circle_green" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginTop="-36dp" android:src="@drawable/ic_verify" app:tint="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Verifikasi Sewa" android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/manage_items_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_card_dark"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="20dp">
                    <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_circle_cyan" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginTop="-36dp" android:src="@drawable/ic_inventory" app:tint="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Kelola Barang" android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">
                
                <LinearLayout
                    android:id="@+id/verify_user_items_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_card_dark"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="20dp">
                    <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_circle_orange" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginTop="-36dp" android:src="@drawable/ic_verify" app:tint="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Barang User" android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/manage_returns_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_card_dark"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="20dp">
                    <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_circle_cyan" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginTop="-36dp" android:src="@drawable/ic_return" app:tint="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Pengembalian" android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <LinearLayout
                    android:id="@+id/view_reports_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_card_dark"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="20dp">
                    <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_circle_purple" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginTop="-36dp" android:src="@drawable/ic_reports" app:tint="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Laporan" android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/customer_service_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_card_dark"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="20dp">
                    <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_circle_green" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginTop="-36dp" android:src="@drawable/ic_help" app:tint="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Bantuan" android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold" />
                    
                    <!-- Ticket Badge (floating) -->
                    <TextView
                        android:id="@+id/tv_ticket_count_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-85dp"
                        android:layout_marginStart="30dp"
                        android:background="@drawable/bg_badge_rejected"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="1dp"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="RentEase v1.0 — Staff Panel"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
